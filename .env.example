# Apollo.io API key (Settings -> Integrations -> API in Apollo).
# Required for /api/search-contacts to work. Set this in Vercel under
# Project Settings -> Environment Variables, and locally in .env.local
# (which is gitignored).
APOLLO_API_KEY=

# ContactOut API key (optional). When set, ContactOut results (personal
# emails + phone numbers) are merged into search results alongside Apollo.
# Leave blank to run on Apollo only. Header auth: sent as the `token` header.
CONTACTOUT_API_KEY=
